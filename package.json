{
  "name": "horde",
  "version": "0.4.0",
  "description": "Your local PHP & DB manager",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "predev": "tsc -p tsconfig.node.json",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-boundaries": "^7.0.2",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.6",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@vueuse/core": "^14.3.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.6",
    "pinia": "^3.0.4",
    "reflect-metadata": "^0.2.2",
    "reka-ui": "^2.10.1",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tsyringe": "^4.10.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  }
}
